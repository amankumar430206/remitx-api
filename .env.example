NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173

POSTGRES_URL=postgresql://remitx:remitx_dev@localhost:5432/remitx
REDIS_URL=redis://localhost:6379

# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPASTE_HERE\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_HERE\n-----END PUBLIC KEY-----"

DEFAULT_PROVIDER=manual
DEFAULT_FX_SPREAD=0.005
FX_CACHE_TTL_SECONDS=10
FX_QUOTE_TTL_SECONDS=120

LOG_LEVEL=info

# SMTP (leave blank in dev to use Ethereal auto-account)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RemitX" <noreply@remitx.io>
